# ─────────────────────────────────────────────────────────────────────────
# VIP Club — environment variables
# Copy this file to `.env` and fill in the values. Everything is OPTIONAL:
# with no keys set, the app runs on seeded in-memory demo data + mock SMS.
# Turn services on one at a time by filling in the matching block.
# ─────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────
# Public base URL of the deployment. Used to build QR links, pass URLs,
# calendar invites, etc. On Vercel this is auto-derived if left blank.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────
# Strong random string used to sign session cookies (HMAC-SHA256).
# Generate one with:  openssl rand -hex 32
AUTH_SECRET=

# ── Database: Neon (Postgres) ────────────────────────────────────────────
# Pooled connection string from the Neon dashboard
# (Project → Connection Details → "Pooled connection").
# Looks like:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
# NOTE: the current data layer (lib/db.ts + lib/supabase.ts) talks to
# Supabase's REST API, not raw Postgres. To actually run on Neon, that layer
# needs to be swapped to a Postgres driver (e.g. @neondatabase/serverless).
# Ask me to do that swap and this variable will be wired up.
DATABASE_URL=

# ── SMS: Twilio ──────────────────────────────────────────────────────────
# Without these, outbound texts are logged to the server console instead of sent.
# Point the number's inbound webhook at /api/sms/inbound for STOP handling.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Email: Resend ────────────────────────────────────────────────────────
# Booking invites (with .ics + Add-to-Calendar links) send for real once set.
# EMAIL_FROM must be on a domain you've verified in Resend.
RESEND_API_KEY=
EMAIL_FROM=

# ── Cron ─────────────────────────────────────────────────────────────────
# Shared secret protecting /api/reminders/run (the daily Vercel Cron job).
# Generate one with:  openssl rand -hex 32
CRON_SECRET=
